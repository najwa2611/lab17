<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="#5C1010"
    android:gravity="center_horizontal">

    <TextView
        android:id="@+id/tvStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Status: Waiting"
        android:textSize="18sp"
        android:textColor="#EEDC82"
        android:layout_marginBottom="32dp"
        android:background="#4A0E17"
        android:padding="12dp"
        android:textStyle="bold" />

    <Button
        android:id="@+id/btnToggleAirplane"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Enable Flight Receiver"
        android:textColor="#000000"
        android:background="#C30101"
        android:layout_marginBottom="16dp"
        android:textStyle="bold" />

    <Button
        android:id="@+id/btnSendCustom"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Send Custom Signal"
        android:textColor="#000000"
        android:background="#D4AF37"
        android:textStyle="bold" />

</LinearLayout>